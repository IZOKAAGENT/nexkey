{
  "version": 2,
  "name": "nexkey",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.1.3"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/index.html"
    }
  ],
  "env": {
    "WHATSAPP_VERIFY_TOKEN": "nexkey_verify_token_2026"
  }
}
